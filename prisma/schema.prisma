generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  clerkId          String    @unique
  email            String    @unique
  name             String?
  phone            String?
  country          String?
  city             String?
  role             UserRole  @default(FAN)
  isVipActive      Boolean   @default(false)
  vipUntil         DateTime?
  stripeCustomerId String?   @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  trajets          Trajet[]
  proProfile       ProProfile?
  unlockedContacts UnlockedContact[]
  quizResults      QuizResult[]
  gameScores       GameScore[]
  afterOwnerships  After[]           @relation("AfterOrganizer")
  payments         Payment[]
  moderator        Moderator?

  @@index([email])
  @@index([clerkId])
}

enum UserRole {
  FAN
  PRO
  ADMIN
}

model Trajet {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  villeDepart     String
  paysDepart      String
  villeArrivee    String   @default("Paris")
  date            DateTime
  heureDepart     String
  placesDispo     Int
  placesTotal     Int
  prix            Float
  vehicule        String?
  vehiculeModel   String?
  vehiculeColor   String?
  carPhoto        String?
  note            String?  @db.Text
  whatsapp        String
  contactRevealed Boolean  @default(false)
  isBoosted       Boolean  @default(false)
  boostUntil      DateTime?
  isActive        Boolean  @default(true)
  views           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([paysDepart, villeDepart, date])
  @@index([isBoosted, createdAt])
}

model ProProfile {
  id              String      @id @default(cuid())
  userId          String      @unique
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        ProCategory
  displayName     String
  slug            String      @unique
  city            String
  country         String
  bio             String?     @db.Text
  specialities    String[]
  photos          String[]
  instagramHandle String?
  tiktokHandle    String?
  whatsapp        String
  priceRange      String?
  rating          Float       @default(0)
  reviewsCount    Int         @default(0)
  isPremium       Boolean     @default(false)
  premiumUntil    DateTime?
  isBoosted       Boolean     @default(false)
  boostUntil      DateTime?
  isVerified      Boolean     @default(false)
  verifiedAt      DateTime?
  views           Int         @default(0)
  contactAttempts Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([category, city])
  @@index([isBoosted, rating])
}

enum ProCategory {
  MAQUILLEUSE
  ESTHETICIENNE
  PROTHESISTE_ONGLES
  TECHNICIENNE_CILS
  COIFFEUR
  BARBIER
  PHOTOGRAPHE
  VIDEASTE
  VENDEUR_MERCH
  ORGANISATEUR_AFTER
  SECURITE
  CHAUFFEUR_VTC
  DJ
  ANIMATEUR
  CUISINIER
  TRAITEUR
  DECORATEUR
  COUTURIER
  BIJOUTIER
  BABYSITTER
  AUTRE
}

model UnlockedContact {
  id         String             @id @default(cuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetId   String
  targetType UnlockedTargetType
  unlockedAt DateTime           @default(now())

  @@unique([userId, targetId, targetType])
  @@index([userId])
}

enum UnlockedTargetType {
  TRAJET
  PRO_PROFILE
}

model After {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String   @db.Text
  date        DateTime
  venue       String
  address     String
  city        String
  capacity    Int?
  priceFrom   Float
  ticketUrl   String
  flyerUrl    String?
  organizerId String?
  organizer   User?    @relation("AfterOrganizer", fields: [organizerId], references: [id])
  isVerified  Boolean  @default(false)
  isBoosted   Boolean  @default(false)
  isActive    Boolean  @default(true)
  views       Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([date, isActive])
}

model MerchProduct {
  id          String   @id @default(cuid())
  vendorName  String
  title       String
  description String?
  imageUrl    String
  price       Float
  externalUrl String
  category    String
  isFeatured  Boolean  @default(false)
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())
}

model ParisClassic {
  id             String   @id @default(cuid())
  name           String
  category       String
  description    String
  address        String
  arrondissement Int?
  priceLevel     Int      @default(2)
  externalUrl    String?
  googleMapsUrl  String?
  phone          String?
  imageUrl       String?
  tags           String[]
  isSponsored    Boolean  @default(false)
  order          Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([category, order])
}

model QuizResult {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  email     String
  answers   Json
  archetype String
  createdAt DateTime @default(now())

  @@index([email])
}

model GameScore {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  pseudo    String
  score     Int
  level     Int      @default(1)
  createdAt DateTime @default(now())

  @@index([score(sort: Desc)])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?
  confirmed Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PromoCode {
  id              String            @id @default(cuid())
  code            String            @unique
  category        PromoCodeCategory
  label           String?
  discountPercent Int               @default(100)
  maxUses         Int               @default(1)
  usedCount       Int               @default(0)
  isActive        Boolean           @default(true)
  expiresAt       DateTime?
  notes           String?           @db.Text
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  redemptions PromoCodeRedemption[]

  @@index([category, isActive])
}

model PromoCodeRedemption {
  id          String    @id @default(cuid())
  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  userEmail   String
  userId      String?
  redeemedAt  DateTime  @default(now())

  @@unique([promoCodeId, userEmail])
  @@index([userEmail])
}

enum PromoCodeCategory {
  VIP_FAN
  PRO
}

model Report {
  id           String         @id @default(cuid())
  targetType   ReportTargetType
  targetId     String
  reason       ReportReason
  description  String?        @db.Text
  reporterEmail String?
  reporterId   String?
  status       ReportStatus   @default(PENDING)
  adminNotes   String?        @db.Text
  resolvedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status, createdAt])
  @@index([targetType, targetId])
}

enum ReportTargetType {
  TRAJET
  PRO_PROFILE
  AFTER
  USER
  MERCH_PRODUCT
}

enum ReportReason {
  ARNAQUE
  FAUX_PROFIL
  SPAM
  CONTENU_INAPPROPRIE
  PRIX_ABUSIF
  CONTACT_NON_REPONSE
  AUTRE
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSessionId String        @unique
  stripePaymentId String?
  type            PaymentType
  amount          Float
  currency        String        @default("eur")
  status          PaymentStatus @default(PENDING)
  metadata        Json?
  createdAt       DateTime      @default(now())
  completedAt     DateTime?

  @@index([userId])
}

enum PaymentType {
  VIP_FAN
  PRO_PREMIUM
  BOOST
  CONDUCTEUR_REVEAL
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Moderator {
  id           String           @id @default(cuid())
  userId       String           @unique
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  region       String
  country      String           @default("France")
  whatsappLink String?
  bio          String?          @db.Text
  motivation   String?          @db.Text
  status       ModeratorStatus  @default(PENDING)
  approvedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  community    WhatsAppCommunity?

  @@index([status, region])
}

enum ModeratorStatus {
  PENDING
  APPROVED
  SUSPENDED
}

model WhatsAppCommunity {
  id           String     @id @default(cuid())
  name         String
  region       String
  country      String     @default("France")
  inviteLink   String
  description  String?    @db.Text
  rules        String?    @db.Text
  memberCount  Int        @default(0)
  isActive     Boolean    @default(true)
  isFeatured   Boolean    @default(false)
  moderatorId  String?    @unique
  moderator    Moderator? @relation(fields: [moderatorId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([region, isActive])
  @@index([country, isActive])
}
